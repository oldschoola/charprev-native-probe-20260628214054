+
+#include <stdarg.h>
+
+#include "windef.h"
+#include "winbase.h"
+#include "winnls.h"
+#include "winuser.h"
+#include "wine/exception.h"
+#include "wine/test.h"
+
+static LPSTR call_CharPrevA(const char *start, const char *ptr, BOOL *got_exception)
+{
+    LPSTR ret = NULL;
+
+    *got_exception = FALSE;
+    __TRY
+    {
+        ret = CharPrevA(start, ptr);
+    }
+    __EXCEPT_PAGE_FAULT
+    {
+        *got_exception = TRUE;
+    }
+    __ENDTRY
+
+    return ret;
+}
+
+static LPSTR call_CharPrevExA(WORD codepage, const char *start, const char *ptr, DWORD flags,
+        BOOL *got_exception)
+{
+    LPSTR ret = NULL;
+
+    *got_exception = FALSE;
+    __TRY
+    {
+        ret = CharPrevExA(codepage, start, ptr, flags);
+    }
+    __EXCEPT_PAGE_FAULT
+    {
+        *got_exception = TRUE;
+    }
+    __ENDTRY
+
+    return ret;
+}
+
+static void test_CharPrev(void)
+{
+    static char str[] = "abc";
+    BOOL got_exception;
+    LPSTR ret;
+
+    ret = CharPrevA(str, str + 2);
+    ok(ret == str + 1, "got %p, expected %p\n", ret, str + 1);
+
+    ret = CharPrevA(str, str);
+    ok(ret == str, "got %p, expected %p\n", ret, str);
+
+    ret = call_CharPrevA(NULL, str + 1, &got_exception);
+    ok(!got_exception, "CharPrevA(NULL, str + 1) raised an exception\n");
+    if (!got_exception)
+        ok(ret == str, "got %p, expected %p\n", ret, str);
+
+    ret = call_CharPrevA(NULL, str + 2, &got_exception);
+    ok(!got_exception, "CharPrevA(NULL, str + 2) raised an exception\n");
+    if (!got_exception)
+        ok(ret == str + 1, "got %p, expected %p\n", ret, str + 1);
+
+    ret = call_CharPrevExA(CP_ACP, NULL, str + 1, 0, &got_exception);
+    ok(!got_exception, "CharPrevExA(CP_ACP, NULL, str + 1, 0) raised an exception\n");
+    if (!got_exception)
+        ok(ret == str, "got %p, expected %p\n", ret, str);
+
+    ret = call_CharPrevExA(CP_ACP, NULL, str + 2, 0, &got_exception);
+    ok(!got_exception, "CharPrevExA(CP_ACP, NULL, str + 2, 0) raised an exception\n");
+    if (!got_exception)
+        ok(ret == str + 1, "got %p, expected %p\n", ret, str + 1);
+}
+
+START_TEST(string)
+{
+    test_CharPrev();
+}
